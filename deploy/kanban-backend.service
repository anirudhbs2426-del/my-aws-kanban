[Unit]
Description=Kanban Dashboard Flask Backend
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/AWS_Challenge/backend
EnvironmentFile=-/home/ubuntu/AWS_Challenge/backend/.env
ExecStart=/home/ubuntu/AWS_Challenge/backend/.venv/bin/gunicorn --workers 3 --bind 127.0.0.1:8000 wsgi:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target